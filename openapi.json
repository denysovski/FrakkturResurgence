{\n  "openapi": "3.0.0",\n  "info": {\n    "title": "Frakktur API",\n    "description": "RESTful API for Frakktur luxury streetwear e-commerce platform. Handles authentication, product management, shopping cart, wishlist, and admin operations.",\n    "version": "1.0.0",\n    "contact": {\n      "name": "Frakktur Development",\n      "url": "https://frakktur.com"\n    },\n    "license": {\n      "name": "Private"\n    }\n  },\n  "servers": [\n    {\n      "url": "https://api.frakktur.com",\n      "description": "Production server",\n      "variables": {}\n    },\n    {\n      "url": "http://localhost:8080",\n      "description": "Development server"\n    }\n  ],\n  "tags": [\n    {\n      "name": "Authentication",\n      "description": "User registration, login, and session management"\n    },\n    {\n      "name": "Products",\n      "description": "Product catalog and search operations"\n    },\n    {\n      "name": "Shopping Cart",\n      "description": "Shopping cart operations\"\n    },\n    {\n      "name": "Wishlist",\n      "description": "User wishlist management\"\n    },\n    {\n      "name": "Admin",\n      "description": "Administrative product and asset management\"\n    }\n  ],\n  "paths": {\n    "/auth.php": {\n      "post": {\n        "tags": ["Authentication"],\n        "summary": "Register new user or perform auth action",\n        "operationId": "register",\n        "parameters": [\n          {\n            "name": "action",\n            "in": "query",\n            "required": true,\n            "schema": {\n              "type": "string",\n              "enum": ["register"]\n            }\n          }\n        ],\n        "requestBody": {\n          "required": true,\n          "content": {\n            "application/json": {\n              "schema": {\n                "type": "object",\n                "required": ["fullName", "email", "password"],\n                "properties": {\n                  "fullName": {\n                    "type": "string",\n                    "minLength": 2,\n                    "maxLength": 120,\n                    "example": "Jan Novotný"\n                  },\n                  "email": {\n                    "type": "string",\n                    "format": "email",\n                    "example": "jan@example.com"\n                  },\n                  "password": {\n                    "type": "string",\n                    "minLength": 6,\n                    "maxLength": 72,\n                    "example": "SecurePassword123"\n                  }\n                }\n              }\n            }\n          }\n        },\n        "responses": {\n          "201": {\n            "description": "User successfully registered",\n            "content": {\n              "application/json": {\n                "schema": {\n                  "type": "object",\n                  "properties": {\n                    "user": {\n                      "type": "object",\n                      "properties": {\n                        "id": {"type": "integer"},\n                        "email": {"type": "string"},\n                        "fullName": {"type": "string"},\n                        "status": {"type": "string"},\n                        "isAdmin": {"type": "boolean"}\n                      }\n                    }\n                  }\n                }\n              }\n            }\n          },\n          "400": {\n            "description": "Validation error"\n          },\n          "409": {\n            "description": "Email already registered"\n          }\n        }\n      },\n      "get": {\n        "tags": ["Products"],\n        "summary": "Get products or product details",\n        "operationId": "getProducts",\n        "parameters": [\n          {\n            "name": "action",\n            "in": "query",\n            "required": true,\n            "schema": {\n              "type": "string",\n              "enum": ["products_by_category", "product_get", "search", "me", "cart_get", "wishlist_get", "admin_products_get", "admin_assets_list", "admin_options"]\n            }\n          },\n          {\n            "name": "category",\n            "in": "query",\n            "schema": {\n              "type": "string",\n              "enum": ["tshirts", "hoodies", "caps", "belts", "pants", "knitwear", "leather-jackets"]\n            }\n          },\n          {\n            "name": "id",\n            "in": "query",\n            "schema": {\n              "type": "string"\n            }\n          },\n          {\n            "name": "q",\n            "in": "query",\n            "schema": {\n              "type": "string"\n            }\n          }\n        ],\n        "responses": {\n          "200": {\n            "description": "Success"\n          },\n          "400": {\n            "description": "Missing required parameters"\n          },\n          "401": {\n            "description": "Unauthorized\"\n          },\n          "403": {\n            "description": "Forbidden - Admin access required"\n          },\n          "404": {\n            "description": "Resource not found\"\n          }\n        }\n      }\n    }\n  },\n  "components": {\n    "schemas": {\n      "User": {\n        "type": "object",\n        "properties": {\n          "id": {"type": "integer"},\n          "email": {"type": "string"},\n          "fullName": {"type": "string"},\n          "status": {"type": "string"},\n          "isAdmin": {"type": "boolean"}\n        }\n      },\n      "Product": {\n        "type": "object",\n        "properties": {\n          "dbId": {"type": "integer"},\n          "id": {"type": "string"},\n          "categoryKey": {"type": "string"},\n          "categoryTitle": {"type": "string"},\n          "name": {"type": "string"},\n          "price": {"type": "string"},\n          "description": {"type": "string"},\n          "material": {"type": "string"},\n          "sustainability": {"type": "string"},\n          "imageKey": {"type": "string"},\n          "sizes": {"type": "array", "items": {"type": "string"}}\n        }\n      },\n      "CartItem": {\n        "type": "object",\n        "properties": {\n          "key": {"type": "string"},\n          "id": {"type": "string"},\n          "categoryKey": {"type": "string"},\n          "name": {"type": "string"},\n          "priceCents": {"type": "integer"},\n          "size": {"type": "string"},\n          "quantity": {"type": "integer"},\n          "imageKey": {"type": "string"}\n        }\n      },\n      "WishlistItem": {\n        "type": "object",\n        "properties": {\n          "key": {"type": "string"},\n          "id": {"type": "string"},\n          "categoryKey": {"type": "string"},\n          "categoryTitle": {"type": "string"},\n          "name": {"type": "string"},\n          "priceCents": {"type": "integer"},\n          "imageKey": {"type": "string"}\n        }\n      },\n      "Error": {\n        "type": "object",\n        "properties": {\n          "error": {"type": "string"}\n        }\n      }\n    },\n    "securitySchemes": {\n      "sessionAuth": {\n        "type": "apiKey",\n        "in": "cookie",\n        "name": "PHPSESSID"\n      }\n    }\n  },\n  "security": [\n    {"sessionAuth": []}\n  ]\n}
