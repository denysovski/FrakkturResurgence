<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /frakkturresurgence/

  RewriteCond %{REQUEST_URI} ^/frakkturresurgence/api/ [NC]
  RewriteRule ^ - [L]

  RewriteCond %{REQUEST_URI} \.(js|mjs|css|map|png|jpe?g|gif|webp|svg|ico|txt|woff2?|ttf|eot)$ [NC]
  RewriteRule ^ - [L]

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule . index.html [L]
</IfModule>
